

<!-- Hero Banner -->
<section class="wl-hero">
  <p class="wl-hero__eyebrow">Discover · Stay · Explore</p>
  <h1 class="wl-hero__title">Find your next <em>adventure</em></h1>
  <p class="wl-hero__sub">Hand-picked stays across the world — from hidden cottages to rooftop lofts.</p>
  <div class="wl-hero__cta-row">
    <a href="/listings/new" class="btn-wl btn-wl--primary">+ Add a Listing</a>
    <a href="#listings" class="btn-wl btn-wl--outline">Browse All</a>
  </div>
</section>

<hr class="wl-divider" />

<!-- Listings Grid -->
<section class="wl-section" id="listings">
  <div class="wl-section__header">
    <h2 class="wl-section__title">All Listings</h2>
    <span class="wl-section__count"><%= allListings.length %> place<%= allListings.length !== 1 ? 's' : '' %></span>
  </div>

  <div class="wl-grid">
    <% if (allListings.length === 0) { %>
      <div class="wl-empty">
        <div class="wl-empty__icon">🗺️</div>
        <h3 class="wl-empty__title">No listings yet</h3>
        <p class="wl-empty__sub">Be the first to share an amazing place.</p>
        <a href="/listings/new" class="btn-wl btn-wl--primary">Add a Listing</a>
      </div>
    <% } else { %>
      <% for (let listing of allListings) { %>
        <div class="wl-card">
          <div class="wl-card__media">
            <div class="wl-card__media-placeholder">✦</div>
          </div>
          <div class="wl-card__body">
            <span class="wl-card__location"><%= listing.location %>, <%= listing.country %></span>
            <h3 class="wl-card__title">
              <a href="/listings/<%= listing._id %>"><%= listing.title %></a>
            </h3>
            <p class="wl-card__desc"><%= listing.description %></p>
            <div class="wl-card__footer">
              <div class="wl-card__price">
                ₹<%= listing.price.toLocaleString("en-IN") %>
                <span class="wl-card__price-unit">/ night</span>
              </div>
              <div class="wl-card__actions">
                <a href="/listings/<%= listing._id %>" class="btn-wl btn-wl--ghost">View</a>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    <% } %>
  </div>
</section>
