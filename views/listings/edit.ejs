
<div class="wl-form-wrap">
  <div class="wl-form-header">
    <p class="wl-form-header__eyebrow">Edit listing</p>
    <h1 class="wl-form-header__title">Update Your Place</h1>
    <p class="wl-form-header__sub">Editing: <strong><%= listing.title %></strong></p>
  </div>

  <div class="wl-form-card">
    <form action="/listings/<%= listing._id %>?_method=PUT" method="POST">

      <div class="wl-field">
        <label for="title">Listing Title</label>
        <input type="text" id="title" name="listing[title]" value="<%= listing.title %>" required />
      </div>

      <div class="wl-field">
        <label for="description">Description</label>
        <textarea id="description" name="listing[description]" required><%= listing.description %></textarea>
      </div>

      <div class="wl-field">
        <label for="image">Image URL</label>
        <input type="url" id="image" name="listing[image][url]" value="<%= listing.image ? listing.image.url : '' %>" placeholder="https://images.unsplash.com/…" />
      </div>
      <input type="hidden" name="listing[image][filename]" value="listingimage" />

      <hr class="wl-form-divider" />

      <div class="wl-form-row">
        <div class="wl-field">
          <label for="location">City / Area</label>
          <input type="text" id="location" name="listing[location]" value="<%= listing.location %>" required />
        </div>
        <div class="wl-field">
          <label for="country">Country</label>
          <input type="text" id="country" name="listing[country]" value="<%= listing.country %>" required />
        </div>
      </div>

      <div class="wl-field">
        <label for="price">Price per Night (₹)</label>
        <input type="number" id="price" name="listing[price]" value="<%= listing.price %>" min="0" required />
      </div>

      <div class="wl-form-footer">
        <a href="/listings/<%= listing._id %>" class="btn-wl btn-wl--ghost">Cancel</a>
        <button type="submit" class="btn-wl btn-wl--primary">Update Listing →</button>
      </div>

    </form>
  </div>
</div>
