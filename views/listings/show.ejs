

<div class="wl-show">

  <div class="wl-show__back">
    <a href="/listings" class="btn-wl btn-wl--ghost">← Back to Listings</a>
  </div>

  <p class="wl-show__eyebrow"><%= listing.location %>, <%= listing.country %></p>
  <h1 class="wl-show__title"><%= listing.title %></h1>

  <div class="wl-show__meta">
    <div class="wl-show__meta-item">
      <span class="wl-show__meta-label">Price</span>
      <span class="wl-show__meta-value">₹<%= listing.price.toLocaleString("en-IN") %><span style="font-size:.8rem;font-family:var(--font-body);color:var(--slate);"> / night</span></span>
    </div>
    <div class="wl-show__meta-item">
      <span class="wl-show__meta-label">Location</span>
      <span class="wl-show__meta-value"><%= listing.location %></span>
    </div>
    <div class="wl-show__meta-item">
      <span class="wl-show__meta-label">Country</span>
      <span class="wl-show__meta-value"><%= listing.country %></span>
    </div>
  </div>

  <p class="wl-show__desc"><%= listing.description %></p>

  <div class="wl-show__actions">
    <a href="/listings/<%= listing._id %>/edit" class="btn-wl btn-wl--outline" style="color:var(--navy);border-color:rgba(13,27,42,.3);">Edit Listing</a>

    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" style="display:inline;">
      <button type="submit" class="btn-wl btn-wl--danger">Delete</button>
    </form>
  </div>

</div>
